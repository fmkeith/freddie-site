---
import { getCollection } from 'astro:content';

const revision = await getCollection('revision');
---

<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width" />
    <title>Freddie Mason — Work Experience 2026</title>
    <style>
      * { margin: 0; padding: 0; box-sizing: border-box; }
      body {
        background: #0d0d0d;
        color: #c8c8c8;
        font-family: Georgia, serif;
        min-height: 100vh;
        padding: 60px 24px;
      }
      .container { max-width: 700px; margin: 0 auto; }
      header { margin-bottom: 60px; }
      .label {
        font-family: monospace;
        font-size: 0.7rem;
        letter-spacing: 3px;
        color: #00ff88;
        text-transform: uppercase;
        margin-bottom: 12px;
      }
      h1 { font-size: 2.4rem; color: #e8e8e8; line-height: 1.2; }
      h1 span { color: #00ff88; }
      .sub { color: #4a7a5a; font-family: monospace; font-size: 0.8rem; margin-top: 10px; letter-spacing: 2px; }
      section { margin-bottom: 48px; }
      h2 { font-size: 1rem; font-family: monospace; color: #00ff88; letter-spacing: 3px; text-transform: uppercase; margin-bottom: 20px; border-bottom: 1px solid #1a3d2a; padding-bottom: 8px; }
      .card {
        display: block;
        text-decoration: none;
        border: 1px solid #1a3d2a;
        border-radius: 6px;
        padding: 18px 22px;
        margin-bottom: 10px;
        transition: border-color 0.2s, background 0.2s;
      }
      .card:hover { border-color: #00ff88; background: #0b1e0f; }
      .card-title { color: #e8e8e8; font-size: 1rem; margin-bottom: 4px; }
      .card-meta { font-family: monospace; font-size: 0.7rem; color: #2e6040; letter-spacing: 1px; }
      .tags { margin-top: 6px; display: flex; gap: 6px; flex-wrap: wrap; }
      .tag { font-family: monospace; font-size: 0.65rem; color: #00ff88; border: 1px solid #1a3d2a; border-radius: 20px; padding: 2px 8px; }
    </style>
  </head>
  <body>
    <div class="container">
      <header>
        <div class="label">// year-10 · 2026</div>
        <h1>Freddie Mason<br><span>Work Experience</span></h1>
        <div class="sub">3 days · web dev · may 2026</div>
      </header>

      <section>
        <h2>Diary</h2>
        <a class="card" href="/diary/wednesday">
          <div class="card-title">Foundations &amp; First Win</div>
          <div class="card-meta">Wednesday, 20 May 2026</div>
        </a>
      </section>

      <section>
        <h2>Revision</h2>
        {revision.map(entry => (
          <a class="card" href={`/revision/${entry.id}`}>
            <div class="card-title">{entry.data.title}</div>
            <div class="card-meta">{entry.data.subject}</div>
            <div class="tags">{entry.data.tags.map(t => <span class="tag">{t}</span>)}</div>
          </a>
        ))}
      </section>
    </div>
  </body>
</html>
